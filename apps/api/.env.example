# Copy to .env for local development. Never commit the real .env (see .gitignore).

DATABASE_URL=postgresql+psycopg://blueprint:blueprint@localhost:5432/blueprint
REDIS_URL=redis://localhost:6379/0

# GitHub App (Phase 0 PR3) — created manually in GitHub's UI, see docs/MEMORY.md.
# All five are required before /api/v1/auth/* endpoints work; the app
# fails fast with the exact missing names (integrations/github/config.py)
# rather than failing confusingly deeper in a request.
GITHUB_APP_ID=
# PEM contents, as a single line with literal "\n" escapes in place of
# real newlines. Do NOT paste the downloaded .pem file's raw multi-line
# contents here directly — python-dotenv reads .env line by line and
# silently truncates an unquoted multi-line value to just its first
# line ("-----BEGIN...-----"), which still looks plausible but fails
# deep inside JWT signing. Convert the downloaded .pem file with:
#   uv run python scripts/format_private_key.py path/to/key.pem >> .env
GITHUB_APP_PRIVATE_KEY=

GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# The App's public URL slug, e.g. "blueprint-dev" for github.com/apps/blueprint-dev
GITHUB_APP_SLUG=
# Not yet consumed (webhook-driven sync is ARCHITECTURE.md §14, v1.1) —
# collected now so it's not a second manual GitHub App setup step later.
GITHUB_WEBHOOK_SECRET=

# Signs Blueprint's own session/state JWTs (ARCHITECTURE.md §14) — a
# Blueprint secret, unrelated to any GitHub credential above.
JWT_SECRET=

# Where GitHub redirects back to and where this API is reachable from
# GitHub's side — must be real, publicly reachable URLs outside local dev.
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000

# Embedding provider, routed via OpenRouter (ARCHITECTURE.md §10)
OPENROUTER_API_KEY=

# Threads' reasoning model — NVIDIA's OpenAI-compatible inference API
# (config.py). Paste your own key below; leave it blank for a
# credential-free local/CI setup (Threads degrades to an honest
# "no reasoning model configured" state instead of failing).
NVIDIA_API_KEY=
NVIDIA_MODEL=nvidia/nemotron-3-ultra-550b-a55b
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Which embedding backend Stage 4 indexes with, and Threads searches with.
# "local_hash" (the default) needs no credentials and works offline, but is
# not accuracy-competitive — fine for tests and local dev, weak for real
# retrieval. Set this to "nvidia" to use the same key as above with a real
# retrieval model; retrieval quality is the difference between Threads
# finding the right file and finding a plausible one.
EMBEDDING_PROVIDER=nvidia
# Must emit vectors matching models.types.EMBEDDING_DIM (1024). Changing to a
# model of a different width requires a migration on both chunk tables.
NVIDIA_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5

ENVIRONMENT=development
